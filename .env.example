APP_NAME="LGD Computation API"
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/lgd
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

MAX_BATCH_SIZE=1000

# LGD model coefficients (re-calibratable without a code change).
LGD_UNSECURED_INTERCEPT=0.55
LGD_UNSECURED_BETA_GOV_10Y=0.015
LGD_UNSECURED_BETA_DJI_VAR=-0.20
LGD_UNSECURED_BETA_SHIFT=0.01

LGD_PARTIAL_COLLATERAL_RATIO=0.40
LGD_PARTIAL_COLLATERAL_HAIRCUT=0.25
